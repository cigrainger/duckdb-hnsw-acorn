# name: test/sql/hnsw/hnsw_filtered_persistence.test
# description: Test filtered HNSW search survives checkpoint/restart
# group: [hnsw]

require vss

# Need persistence for checkpoint/restart
load __TEST_DIR__/hnsw_filtered_persist.db

statement ok
SET hnsw_enable_experimental_persistence = true;

statement ok
CREATE TABLE items AS
SELECT i AS id,
    array_value((i % 10)::FLOAT, ((i * 7) % 13)::FLOAT, ((i * 3) % 17)::FLOAT) AS vec,
    (i % 5) AS category
FROM range(500) t(i);

statement ok
CREATE INDEX items_idx ON items USING HNSW (vec);

# Verify filtered search works before checkpoint
query I
SELECT count(*) FROM (
    SELECT * FROM items
    WHERE category = 1
    ORDER BY array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3])
    LIMIT 10
) sub WHERE sub.category != 1;
----
0

# Checkpoint to persist
statement ok
CHECKPOINT;

# Restart
restart

# Verify the index is still there
query II
EXPLAIN SELECT * FROM items ORDER BY array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]) LIMIT 3;
----
physical_plan	<REGEX>:.*HNSW_INDEX_SCAN.*

# Verify filtered search still works after restart
query I
SELECT count(*) FROM (
    SELECT * FROM items
    WHERE category = 1
    ORDER BY array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3])
    LIMIT 10
) sub WHERE sub.category != 1;
----
0

# Verify results are ordered by distance after restart
query I
SELECT bool_and(d1 <= d2) FROM (
    SELECT
        array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]) AS d1,
        LEAD(array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3])) OVER () AS d2
    FROM items
    WHERE category = 2
    ORDER BY array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3])
    LIMIT 20
) sub WHERE d2 IS NOT NULL;
----
true
