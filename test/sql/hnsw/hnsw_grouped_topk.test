# ==================================================================
# 7. Per-group results are valid (each ID belongs to its group)
# ==================================================================
statement ok
CREATE INDEX idx ON items USING HNSW (vec);

# k=3: unnest and verify every returned ID has the correct category
query I
SELECT count(*) FROM (
    SELECT category, unnest(min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 3)) AS closest_id
    FROM items GROUP BY category
) sub
WHERE NOT EXISTS (
    SELECT 1 FROM items WHERE items.id = sub.closest_id AND items.category = sub.category
);
----
0

# k=5: same check
query I
SELECT count(*) FROM (
    SELECT category, unnest(min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 5)) AS closest_id
    FROM items GROUP BY category
) sub
WHERE NOT EXISTS (
    SELECT 1 FROM items WHERE items.id = sub.closest_id AND items.category = sub.category
);
----
0

# k=1: same check
query I
SELECT count(*) FROM (
    SELECT category, unnest(min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 1)) AS closest_id
    FROM items GROUP BY category
) sub
WHERE NOT EXISTS (
    SELECT 1 FROM items WHERE items.id = sub.closest_id AND items.category = sub.category
);
----
0

# ==================================================================
# 8. Per-group results contain valid IDs that exist in the table
# ==================================================================
query I
SELECT count(*) FROM (
    SELECT category, unnest(min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 5)) AS cid
    FROM items GROUP BY category
) sub WHERE cid NOT IN (SELECT id FROM items);
----
0

# ==================================================================
# 9. WHERE filter combined with GROUP BY
# ==================================================================

# Only categories 1 and 3
query I
SELECT count(*) FROM (
    SELECT category, min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 3) AS closest
    FROM items
    WHERE category IN (1, 3)
    GROUP BY category
);
----
2

# Verify only the requested categories are present
query I
SELECT count(DISTINCT category) FROM (
    SELECT category, unnest(min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 3)) AS closest_id
    FROM items
    WHERE category IN (1, 3)
    GROUP BY category
);
----
2

# All returned IDs have the correct category
query I
SELECT count(*) FROM (
    SELECT category, unnest(min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 3)) AS closest_id
    FROM items
    WHERE category IN (1, 3)
    GROUP BY category
) sub
WHERE NOT EXISTS (
    SELECT 1 FROM items WHERE items.id = sub.closest_id AND items.category = sub.category
);
----
0

# Single category via WHERE
query I
SELECT count(*) FROM (
    SELECT category, min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 3) AS closest
    FROM items
    WHERE category = 2
    GROUP BY category
);
----
1

# WHERE filter with brute force comparison
statement ok
CREATE TABLE idx_filtered AS
SELECT category, min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 3) AS closest
FROM items WHERE category IN (1, 3) GROUP BY category;

statement ok
DROP INDEX idx;

statement ok
CREATE TABLE bf_filtered AS
