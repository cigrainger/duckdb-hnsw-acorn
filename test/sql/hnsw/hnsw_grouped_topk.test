# ==================================================================
# 15. Skewed group sizes
# ==================================================================
# Group 0: 450 rows, groups 1-9: 50 rows each (skewed but all from modular arithmetic)
statement ok
CREATE TABLE skewed AS
SELECT i AS id,
    array_value(i::FLOAT, (i*2)::FLOAT, (i*3)::FLOAT) AS vec,
    (i % 10) AS category
FROM range(500) t(i);

# Make it skewed by adding 450 more rows to category 0
statement ok
INSERT INTO skewed SELECT i + 500 AS id,
    array_value((i + 500)::FLOAT, ((i + 500)*2)::FLOAT, ((i + 500)*3)::FLOAT) AS vec,
    0 AS category
FROM range(450) t(i);

statement ok
CREATE INDEX idx_sk ON skewed USING HNSW (vec);

# All 10 groups present
query I
SELECT count(*) FROM (
    SELECT category, min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 3) AS closest
    FROM skewed GROUP BY category
);
----
10

# Per-group validity (critical for skewed — small groups must not bleed)
query I
SELECT count(*) FROM (
    SELECT category, unnest(min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 3)) AS closest_id
    FROM skewed GROUP BY category
) sub
WHERE NOT EXISTS (
    SELECT 1 FROM skewed WHERE skewed.id = sub.closest_id AND skewed.category = sub.category
);
----
0

# k=5 for a regular group (50 items for groups 1-9) — should return 5
query I
SELECT len(closest) FROM (
    SELECT category, min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 5) AS closest
    FROM skewed GROUP BY category
) WHERE category = 1;
----
5

# k=5 for the large group (category 0 has 500 items) — should return 5
query I
SELECT len(closest) FROM (
    SELECT category, min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 5) AS closest
    FROM skewed GROUP BY category
) WHERE category = 0;
----
5

# Brute force comparison for skewed
statement ok
CREATE TABLE idx_sk_res AS
SELECT category, min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 3) AS closest
FROM skewed GROUP BY category;

statement ok
DROP INDEX idx_sk;

statement ok
CREATE TABLE bf_sk_res AS
SELECT category, min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 3) AS closest
FROM skewed GROUP BY category;

query I
SELECT count(*) FROM idx_sk_res ig
WHERE EXISTS (
    SELECT 1 FROM bf_sk_res bg WHERE bg.category = ig.category AND bg.closest = ig.closest
);
----
10

statement ok
DROP TABLE idx_sk_res;

statement ok
DROP TABLE bf_sk_res;

statement ok
DROP TABLE skewed;

