# ==================================================================
# 11. Cosine metric with grouped min_by
# ==================================================================
# Use non-collinear vectors to avoid degenerate cosine ties
statement ok
CREATE TABLE items_cos AS
SELECT i AS id,
    array_value(
        (i % 10 + 1)::FLOAT,
        ((i * 7) % 13 + 1)::FLOAT,
        ((i * 3) % 17 + 1)::FLOAT
    ) AS vec,
    (i % 5) AS category
FROM range(500) t(i);

statement ok
CREATE INDEX idx_cos ON items_cos USING HNSW (vec) WITH (metric = 'cosine');

# EXPLAIN check
query II
EXPLAIN SELECT category, min_by(id, array_cosine_distance(vec, [1.0, 5.0, 10.0]::FLOAT[3]), 3) FROM items_cos GROUP BY category;
----
physical_plan	<REGEX>:.*HNSW_INDEX_SCAN.*

# All groups returned
query I
SELECT count(*) FROM (
    SELECT category, min_by(id, array_cosine_distance(vec, [1.0, 5.0, 10.0]::FLOAT[3]), 3) AS closest
    FROM items_cos GROUP BY category
);
----
5

# Per-group validity
query I
SELECT count(*) FROM (
    SELECT category, unnest(min_by(id, array_cosine_distance(vec, [1.0, 5.0, 10.0]::FLOAT[3]), 3)) AS closest_id
    FROM items_cos GROUP BY category
) sub
WHERE NOT EXISTS (
    SELECT 1 FROM items_cos WHERE items_cos.id = sub.closest_id AND items_cos.category = sub.category
);
----
0

# Brute force comparison
statement ok
CREATE TABLE idx_cos_res AS
SELECT category, min_by(id, array_cosine_distance(vec, [1.0, 5.0, 10.0]::FLOAT[3]), 3) AS closest
FROM items_cos GROUP BY category;

statement ok
DROP INDEX idx_cos;

statement ok
CREATE TABLE bf_cos_res AS
SELECT category, min_by(id, array_cosine_distance(vec, [1.0, 5.0, 10.0]::FLOAT[3]), 3) AS closest
FROM items_cos GROUP BY category;

# Exact brute-force match (non-collinear vectors avoid ties)
query I
SELECT count(*) FROM idx_cos_res ig
WHERE EXISTS (
    SELECT 1 FROM bf_cos_res bg WHERE bg.category = ig.category AND bg.closest = ig.closest
);
----
5

statement ok
DROP TABLE idx_cos_res;

statement ok
DROP TABLE bf_cos_res;

statement ok
DROP TABLE items_cos;

