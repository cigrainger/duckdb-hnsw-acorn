# ==================================================================
# 18. Grouped min_by with expression-based group key
# ==================================================================
statement ok
CREATE TABLE expr_grp AS
SELECT i AS id,
    array_value(i::FLOAT, (i*2)::FLOAT, (i*3)::FLOAT) AS vec,
    i AS raw_cat
FROM range(300) t(i);

statement ok
CREATE INDEX idx_eg ON expr_grp USING HNSW (vec);

# Group by an expression (raw_cat % 10) rather than a plain column
query I
SELECT count(*) FROM (
    SELECT raw_cat % 10 AS grp, min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 3) AS closest
    FROM expr_grp GROUP BY raw_cat % 10
);
----
10

statement ok
DROP TABLE expr_grp;

# ==================================================================
# 19. Grouped min_by with negative query vector
# ==================================================================
statement ok
CREATE TABLE neg_q AS
SELECT i AS id,
    array_value((i - 250)::FLOAT, ((i - 250) * 2)::FLOAT, ((i - 250) * 3)::FLOAT) AS vec,
    (i % 5) AS category
FROM range(500) t(i);

statement ok
CREATE INDEX idx_nq ON neg_q USING HNSW (vec);

# Negative query vector targets different region of space
statement ok
CREATE TABLE idx_nq_res AS
