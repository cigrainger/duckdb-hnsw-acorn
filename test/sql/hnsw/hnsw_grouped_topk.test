# ==================================================================
# 20. Two groups with WHERE that eliminates all but one
# ==================================================================
statement ok
CREATE TABLE two_grp AS
SELECT i AS id,
    array_value(i::FLOAT, (i*2)::FLOAT, (i*3)::FLOAT) AS vec,
    (i % 2) AS category
FROM range(200) t(i);

statement ok
CREATE INDEX idx_2g ON two_grp USING HNSW (vec);

# WHERE eliminates one group entirely
query I
SELECT count(*) FROM (
    SELECT category, min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 3) AS closest
    FROM two_grp
    WHERE category = 0
    GROUP BY category
);
----
1

query I
SELECT category FROM (
    SELECT category, min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 3) AS closest
    FROM two_grp
    WHERE category = 0
    GROUP BY category
);
----
0

statement ok
DROP TABLE two_grp;

# ==================================================================
# 21. Grouped min_by with string group column
# ==================================================================
statement ok
CREATE TABLE str_grp AS
SELECT i AS id,
    array_value(i::FLOAT, (i*2)::FLOAT, (i*3)::FLOAT) AS vec,
    CASE i % 3 WHEN 0 THEN 'alpha' WHEN 1 THEN 'beta' ELSE 'gamma' END AS label
FROM range(300) t(i);

statement ok
CREATE INDEX idx_str ON str_grp USING HNSW (vec);

# 3 groups with string labels
query I
SELECT count(*) FROM (
    SELECT label, min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 3) AS closest
    FROM str_grp GROUP BY label
);
----
3

# Per-group validity
query I
SELECT count(*) FROM (
    SELECT label, unnest(min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 3)) AS closest_id
    FROM str_grp GROUP BY label
) sub
WHERE NOT EXISTS (
    SELECT 1 FROM str_grp WHERE str_grp.id = sub.closest_id AND str_grp.label = sub.label
);
----
0

statement ok
DROP TABLE str_grp;

# ==================================================================
# 22. Grouped min_by with RaBitQ + cosine combined
# ==================================================================
statement ok
CREATE TABLE rq_cos AS
SELECT i AS id,
    array_value((i + 1)::FLOAT, ((i + 1)*2)::FLOAT, ((i + 1)*3)::FLOAT) AS vec,
    (i % 4) AS category
FROM range(400) t(i);

statement ok
CREATE INDEX idx_rqc ON rq_cos USING HNSW (vec) WITH (metric = 'cosine', quantization = 'rabitq');

query I
SELECT count(*) FROM (
    SELECT category, min_by(id, array_cosine_distance(vec, [1.0, 5.0, 10.0]::FLOAT[3]), 3) AS closest
    FROM rq_cos GROUP BY category
);
----
4

# Per-group validity
query I
SELECT count(*) FROM (
    SELECT category, unnest(min_by(id, array_cosine_distance(vec, [1.0, 5.0, 10.0]::FLOAT[3]), 3)) AS closest_id
    FROM rq_cos GROUP BY category
) sub
WHERE NOT EXISTS (
    SELECT 1 FROM rq_cos WHERE rq_cos.id = sub.closest_id AND rq_cos.category = sub.category
);
----
0

statement ok
DROP TABLE rq_cos;

# ==================================================================
# 23. Large k relative to group size
# ==================================================================
statement ok
CREATE TABLE large_k AS
SELECT i AS id,
    array_value(i::FLOAT, (i*2)::FLOAT, (i*3)::FLOAT) AS vec,
    (i % 5) AS category
FROM range(50) t(i);

statement ok
CREATE INDEX idx_lk ON large_k USING HNSW (vec);

# k=20 but each group has only 10 items — should return 10 per group
query I
SELECT bool_and(len(closest) = 10) FROM (
    SELECT category, min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 20) AS closest
    FROM large_k GROUP BY category
);
----
true

statement ok
DROP TABLE large_k;

# ==================================================================
# 24. Verify no duplicate IDs within a group's result list
# ==================================================================
statement ok
CREATE TABLE no_dup AS
SELECT i AS id,
    array_value(i::FLOAT, (i*2)::FLOAT, (i*3)::FLOAT) AS vec,
    (i % 5) AS category
FROM range(500) t(i);

statement ok
CREATE INDEX idx_nd ON no_dup USING HNSW (vec);

# Unnest and check for duplicates within each group
query I
SELECT count(*) FROM (
    SELECT category, closest_id, count(*) AS cnt FROM (
        SELECT category, unnest(min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 10)) AS closest_id
        FROM no_dup GROUP BY category
    ) sub
    GROUP BY category, closest_id
    HAVING count(*) > 1
);
----
0

statement ok
DROP TABLE no_dup;

# ==================================================================
# 25. Multiple queries in sequence (index reuse)
# ==================================================================
statement ok
CREATE TABLE multi_q AS
SELECT i AS id,
    array_value(i::FLOAT, (i*2)::FLOAT, (i*3)::FLOAT) AS vec,
    (i % 5) AS category
FROM range(500) t(i);

statement ok
CREATE INDEX idx_mq ON multi_q USING HNSW (vec);

# First query
query I
SELECT count(*) FROM (
    SELECT category, min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 3) AS closest
    FROM multi_q GROUP BY category
);
----
5

# Second query, different vector
query I
SELECT count(*) FROM (
    SELECT category, min_by(id, array_distance(vec, [200.0, 400.0, 600.0]::FLOAT[3]), 3) AS closest
    FROM multi_q GROUP BY category
);
----
5

# Third query, different k
query I
SELECT count(*) FROM (
    SELECT category, min_by(id, array_distance(vec, [50.0, 100.0, 150.0]::FLOAT[3]), 7) AS closest
    FROM multi_q GROUP BY category
);
----
5

statement ok
