# name: test/sql/hnsw/hnsw_grouped_topk.test
# description: Grouped min_by optimization — per-group ACORN-1 filtered HNSW search
# group: [hnsw]

require hnsw_acorn

# ------------------------------------------------------------------
# Setup: 500 rows, 3 dims, 5 groups (100 rows each)
# ------------------------------------------------------------------
statement ok
CREATE TABLE items AS
SELECT i AS id,
    array_value(i::FLOAT, (i*2)::FLOAT, (i*3)::FLOAT) AS vec,
    (i % 5) AS category
FROM range(500) t(i);

statement ok
CREATE INDEX idx ON items USING HNSW (vec);

# ==================================================================
# 1. EXPLAIN: grouped min_by uses HNSW index scan
# ==================================================================
query II
EXPLAIN SELECT category, min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 3) FROM items GROUP BY category;
----
physical_plan	<REGEX>:.*HNSW_INDEX_SCAN.*

# Also with k=1
query II
EXPLAIN SELECT category, min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 1) FROM items GROUP BY category;
----
physical_plan	<REGEX>:.*HNSW_INDEX_SCAN.*

# Also with k=5
query II
EXPLAIN SELECT category, min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 5) FROM items GROUP BY category;
----
physical_plan	<REGEX>:.*HNSW_INDEX_SCAN.*

# ==================================================================
# 2. Ungrouped min_by still works (regression check)
# ==================================================================
query I
SELECT len(min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 5)) FROM items;
----
5

query I
SELECT len(min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 10)) FROM items;
----
10

# Ungrouped min_by without k returns a scalar
query I
SELECT min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3])) FROM items;
----
1

# ==================================================================
# 3. Grouped min_by k=3: exact match with brute force
# ==================================================================
statement ok
CREATE TABLE idx_k3 AS
SELECT category, min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 3) AS closest
FROM items GROUP BY category;

statement ok
DROP INDEX idx;

statement ok
CREATE TABLE bf_k3 AS
SELECT category, min_by(id, array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]), 3) AS closest
FROM items GROUP BY category;

# All 5 groups present in index results
query I
SELECT count(*) FROM idx_k3;
----
5

# All 5 groups present in brute force results
query I
SELECT count(*) FROM bf_k3;
----
5

# Every group's results match exactly
query I
SELECT count(*) FROM idx_k3 ig
WHERE EXISTS (
    SELECT 1 FROM bf_k3 bg
    WHERE bg.category = ig.category AND bg.closest = ig.closest
);
----
5

# No mismatches in the other direction either
query I
SELECT count(*) FROM bf_k3 bg
WHERE NOT EXISTS (
    SELECT 1 FROM idx_k3 ig
    WHERE ig.category = bg.category AND ig.closest = bg.closest
);
----
0

# Each group returns exactly 3 results
query I
SELECT bool_and(len(closest) = 3) FROM idx_k3;
----
true

statement ok
DROP TABLE idx_k3;

statement ok
DROP TABLE bf_k3;

