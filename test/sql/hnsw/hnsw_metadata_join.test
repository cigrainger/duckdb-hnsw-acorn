    SELECT e.id, m.category
    FROM embeddings e JOIN metadata m ON e.id = m.id
    WHERE m.category = 1 AND e.id > 500
    ORDER BY array_distance(e.vec, [1.0, 2.0, 3.0]::FLOAT[3])
    LIMIT 10
) sub WHERE sub.category != 1 OR sub.id <= 500;
