statement ok
CREATE TABLE embeddings AS
SELECT i AS id, array_value(
    (i % 10 + 1)::FLOAT,
    ((i * 7) % 13 + 1)::FLOAT,
    ((i * 3) % 17 + 1)::FLOAT
) AS vec FROM range(500) t(i);

statement ok
CREATE INDEX idx_cos ON embeddings USING HNSW (vec) WITH (metric = 'cosine');

statement ok
