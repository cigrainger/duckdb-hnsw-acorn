SELECT m.name, array_cosine_distance(e.vec, [1.0, 5.0, 10.0]::FLOAT[3]) AS dist
FROM embeddings e JOIN metadata m ON e.id = m.id
WHERE m.category = 1
ORDER BY dist LIMIT 10;

