# ==================================================================
# 12. Non-1:1 join (metadata has duplicates) — TOP_N prevents excess
# ==================================================================
statement ok
CREATE TABLE meta_dupes AS
SELECT * FROM metadata
UNION ALL
SELECT i AS id, (i % 5) AS category, (i % 3) AS tag, 'dupe_' || i AS name
FROM range(500) t(i);

# Each id now has 2 rows in meta_dupes. Without TOP_N, the join
# would produce 2x rows. LIMIT should cap the result.
query I
SELECT count(*) FROM (
    SELECT m.name
    FROM embeddings e JOIN meta_dupes m ON e.id = m.id
    WHERE m.category = 1
    ORDER BY array_distance(e.vec, [1.0, 2.0, 3.0]::FLOAT[3])
    LIMIT 10
) sub;
----
10

# Filter still correct with duplicates
query I
SELECT count(*) FROM (
    SELECT m.category
    FROM embeddings e JOIN meta_dupes m ON e.id = m.id
    WHERE m.category = 1
    ORDER BY array_distance(e.vec, [1.0, 2.0, 3.0]::FLOAT[3])
    LIMIT 10
) sub WHERE sub.category != 1;
----
0

# LIMIT 5 with dupes
query I
SELECT count(*) FROM (
    SELECT m.name
    FROM embeddings e JOIN meta_dupes m ON e.id = m.id
    WHERE m.category = 3
    ORDER BY array_distance(e.vec, [1.0, 2.0, 3.0]::FLOAT[3])
    LIMIT 5
) sub;
----
5

statement ok
DROP TABLE meta_dupes;

