# ==================================================================
# 18. LIMIT larger than matching rows
# ==================================================================

# category=0 with 2500 rows and 10 categories → 250 matching rows
query I
SELECT count(*) FROM (
    SELECT m.name
    FROM embeddings e JOIN metadata m ON e.id = m.id
    WHERE m.category = 0
    ORDER BY array_distance(e.vec, [1.0, 2.0, 3.0]::FLOAT[3])
    LIMIT 1000
);
----
250

# Very restrictive compound filter: few matches, LIMIT much larger
# category=1 AND tag=0 AND id BETWEEN 0 AND 99 → ids where i%10=1 AND i%4=0 AND i<100
# i%10=1 AND i%4=0 → i∈{21, 61} (checking: 1%4=1 no, 21%4=1 no, 41%4=1 no, 61%4=1 no, 81%4=1 no)
# Actually: i%10=1 AND i%4=0 → need i≡1 mod10 AND i≡0 mod4. No solutions (1 mod4 ≠ 0).
# Use: category=0 AND tag=0 AND id BETWEEN 0 AND 99 → i%10=0 AND i%4=0 → i∈{0,20,40,60,80} = 5 matches
query I
SELECT count(*) FROM (
    SELECT m.name
    FROM embeddings e JOIN metadata m ON e.id = m.id
    WHERE m.category = 0 AND m.tag = 0 AND e.id BETWEEN 0 AND 99
    ORDER BY array_distance(e.vec, [1.0, 2.0, 3.0]::FLOAT[3])
    LIMIT 1000
) sub;
----
5

# Verify results satisfy all filters
query I
SELECT count(*) FROM (
    SELECT e.id, m.category, m.tag
    FROM embeddings e JOIN metadata m ON e.id = m.id
    WHERE m.category = 0 AND m.tag = 0 AND e.id BETWEEN 0 AND 99
    ORDER BY array_distance(e.vec, [1.0, 2.0, 3.0]::FLOAT[3])
    LIMIT 1000
) sub WHERE sub.category != 0 OR sub.tag != 0 OR sub.id < 0 OR sub.id > 99;
----
0

# ==================================================================
# 19. Additional invariants and edge cases
# ==================================================================

# No WHERE clause on metadata — should still use the index (unfiltered join)
query I
SELECT count(*) FROM (
    SELECT m.name
    FROM embeddings e JOIN metadata m ON e.id = m.id
    ORDER BY array_distance(e.vec, [1.0, 2.0, 3.0]::FLOAT[3])
    LIMIT 10
);
----
10

# Distance values are non-negative (L2sq is always >= 0)
query I
SELECT count(*) FROM (
    SELECT array_distance(e.vec, [1.0, 2.0, 3.0]::FLOAT[3]) AS dist
    FROM embeddings e JOIN metadata m ON e.id = m.id
    WHERE m.category = 2
    ORDER BY dist
    LIMIT 10
) sub WHERE sub.dist < 0;
----
0

# Results from different categories are disjoint
statement ok
CREATE TABLE cat1_results AS
SELECT e.id FROM embeddings e JOIN metadata m ON e.id = m.id
WHERE m.category = 1
ORDER BY array_distance(e.vec, [1.0, 2.0, 3.0]::FLOAT[3])
LIMIT 10;

statement ok
CREATE TABLE cat2_results AS
SELECT e.id FROM embeddings e JOIN metadata m ON e.id = m.id
WHERE m.category = 2
ORDER BY array_distance(e.vec, [1.0, 2.0, 3.0]::FLOAT[3])
LIMIT 10;

query I
SELECT count(*) FROM cat1_results c1
WHERE EXISTS (SELECT 1 FROM cat2_results c2 WHERE c2.id = c1.id);
----
0

statement ok
DROP TABLE cat1_results;

statement ok
DROP TABLE cat2_results;

# ==================================================================
# 20. RaBitQ + L2sq + metadata join combo (cosine skipped here because
# the large dataset uses collinear vectors [i, 2i, 3i] which are
# degenerate for cosine distance — see cosine test section above)
# ==================================================================
statement ok
DROP INDEX idx;

statement ok
CREATE INDEX idx_rq ON embeddings USING HNSW (vec) WITH (quantization = 'rabitq');

query I
SELECT count(*) FROM (
    SELECT m.name
    FROM embeddings e JOIN metadata m ON e.id = m.id
    WHERE m.category = 3
    ORDER BY array_distance(e.vec, [1.0, 2.0, 3.0]::FLOAT[3])
    LIMIT 10
) sub;
----
10

query I
SELECT count(*) FROM (
    SELECT m.category
    FROM embeddings e JOIN metadata m ON e.id = m.id
    WHERE m.category = 3
    ORDER BY array_distance(e.vec, [1.0, 2.0, 3.0]::FLOAT[3])
    LIMIT 10
) sub WHERE sub.category != 3;
----
0

statement ok
DROP INDEX idx_rq;

