# name: test/sql/hnsw/hnsw_filtered_crud.test
# description: Test filtered HNSW search after inserts and deletes
# group: [hnsw]

require vss

statement ok
CREATE TABLE items AS
SELECT i AS id,
    array_value((i % 10)::FLOAT, ((i * 7) % 13)::FLOAT, ((i * 3) % 17)::FLOAT) AS vec,
    (i % 5) AS category
FROM range(500) t(i);

statement ok
CREATE INDEX items_idx ON items USING HNSW (vec);

# Baseline: filtered search works
query I
SELECT count(*) FROM (
    SELECT * FROM items WHERE category = 1
    ORDER BY array_distance(vec, [1.0, 2.0, 3.0]::FLOAT[3]) LIMIT 10
) sub WHERE sub.category != 1;
----
0

# Insert new rows
statement ok
INSERT INTO items
SELECT i + 500 AS id,
    array_value(((i + 500) % 10)::FLOAT, (((i + 500) * 7) % 13)::FLOAT, (((i + 500) * 3) % 17)::FLOAT) AS vec,
    ((i + 500) % 5) AS category
FROM range(200) t(i);

# Filtered search should still work after insert
# All returned rows must satisfy the filter
query I
SELECT count(*) FROM (
    SELECT * FROM items WHERE category = 3
    ORDER BY array_distance(vec, [5.0, 6.0, 7.0]::FLOAT[3]) LIMIT 10
) sub WHERE sub.category != 3;
----
0

# Delete some rows
statement ok
DELETE FROM items WHERE id < 100;

# Filtered search should still work after delete
query I
SELECT count(*) FROM (
    SELECT * FROM items WHERE category = 0
    ORDER BY array_distance(vec, [2.0, 3.0, 4.0]::FLOAT[3]) LIMIT 10
) sub WHERE sub.category != 0;
----
0

# Verify no deleted rows appear in results
query I
SELECT count(*) FROM (
    SELECT * FROM items WHERE category = 0
    ORDER BY array_distance(vec, [2.0, 3.0, 4.0]::FLOAT[3]) LIMIT 10
) sub WHERE sub.id < 100;
----
0
