# name: test/sql/hnsw/hnsw_lateral_join_group.test
# group: [hnsw]

require hnsw_acorn

statement ok
SELECT setseed(0.1337);

statement ok
CREATE TABLE queries (id INT, embedding FLOAT[3]);

statement ok
INSERT INTO queries VALUES (1, [5, 5, 5]::FLOAT[3]), (2, [42, 42, 42]::FLOAT[3]);

statement ok
CREATE TABLE items (id INT, embedding FLOAT[3]);

statement ok
INSERT INTO items SELECT i, [random(), random(), random()]::FLOAT[3] FROM range(1, 10000) as r(i);

query II rowsort scan_result
SELECT queries.id as id, nbr
FROM queries, LATERAL (
	SELECT items.id as nbr, array_distance(items.embedding, queries.embedding) as dist
	FROM items
	ORDER BY dist
	LIMIT 3
);
----
1	1243
1	4885
1	9309
2	1243
2	4885
2	9309

query II rowsort group_result
SELECT queries.id as id, list(nbr ORDER BY dist, nbr)
FROM queries, LATERAL (
	SELECT items.id as nbr, array_distance(queries.embedding, items.embedding) as dist
	FROM items
	ORDER BY dist
	LIMIT 3
) GROUP BY id;
----
1	[4885, 1243, 9309]
2	[4885, 1243, 9309]


# Now create an index on the items table
statement ok
CREATE INDEX items_embedding_idx ON items USING hnsw(embedding);

# With the index, the lateral join uses HNSW_INDEX_JOIN (approximate search).
# Results may differ from brute force, so verify count, structure, and validity
# instead of exact value matching.

# Correct count: 2 queries × 3 results = 6 rows
query I
SELECT count(*) FROM (
	SELECT queries.id as id, nbr
	FROM queries, LATERAL (
		SELECT items.id as nbr, array_distance(items.embedding, queries.embedding) as dist
		FROM items
		ORDER BY dist
		LIMIT 3
	)
);
----
6

# All nbr values exist in items table
query I
SELECT count(*) FROM (
	SELECT queries.id as id, nbr
	FROM queries, LATERAL (
		SELECT items.id as nbr, array_distance(items.embedding, queries.embedding) as dist
		FROM items
		ORDER BY dist
		LIMIT 3
	)
) sub WHERE sub.nbr NOT IN (SELECT id FROM items);
----
0

# All id values exist in queries table
query I
SELECT count(*) FROM (
	SELECT queries.id as id, nbr
	FROM queries, LATERAL (
		SELECT items.id as nbr, array_distance(items.embedding, queries.embedding) as dist
		FROM items
		ORDER BY dist
		LIMIT 3
	)
) sub WHERE sub.id NOT IN (SELECT id FROM queries);
----
0

# GROUP BY produces one row per query
query I
SELECT count(*) FROM (
	SELECT queries.id as id, list(nbr ORDER BY dist, nbr)
	FROM queries, LATERAL (
		SELECT items.id as nbr, array_distance(queries.embedding, items.embedding) as dist
		FROM items
		ORDER BY dist
		LIMIT 3
	) GROUP BY id
);
----
2
